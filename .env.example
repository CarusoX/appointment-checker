TELEGRAM_BOT_TOKEN=your_bot_token
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
ENCRYPTION_KEY=your_fernet_key

# Shared secret for authenticating /check and /setup-webhook requests
CRON_SECRET=your_random_secret

# Public base URL of the deployed app (used for Telegram webhook registration)
WEBHOOK_BASE_URL=https://your-app.onrender.com

# Secret token for verifying Telegram webhook requests (set during /setup-webhook)
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret
